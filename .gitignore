.DS_Store

# ---- ML experiment artifacts ----
# Datasets & downloaded data (keep small sample data explicitly with git add -f).
# Root-anchored with a leading slash so these ONLY match the top-level download
# dirs -- a bare `data/`/`datasets/` would also ignore any same-named source
# package (e.g. src/cl_experiments/data/). Same trap as the `models/` note below.
/data/
/datasets/
!/datasets/.gitkeep

# Model checkpoints & weights (NOTE: do not add a bare `models/` here -- it would
# also ignore the src/cl_experiments/models/ source package)
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.h5
*.pkl
*.joblib
checkpoints/
weights/

# Experiment outputs / logs / results
results/
outputs/
logs/
runs/
*.log

# Experiment tracking
wandb/
mlruns/
.mlflow/
lightning_logs/
tensorboard/
tb_logs/
events.out.tfevents.*

# Bayesian optimization state dumps
*.bo_state
optuna.db
*.sqlite3

# ---- Secrets / env ----
.env
.env.*
!.env.example
*.key
secrets/